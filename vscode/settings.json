{
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "go.formatTool": "gofmt",
  "go.lintTool": "golint",
  "editor.formatOnPaste": true,
  "[go]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "golang.go",
  },
  "[rust]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "rust-lang.rust-analyzer",
  },
  "makefile.configureOnOpen": true,
  "github.copilot.editor.enableAutoCompletions": false,
  "amp.url": "https://ampcode.com/",
  "git.openRepositoryInParentFolders": "always",
  "zig.zls.enabled": "on",
  "github.copilot.enable": {
    "*": false,
    "plaintext": false,
    "markdown": false,
    "scminput": false,
  },
  "github.copilot.nextEditSuggestions.enabled": true,
  "vim.useSystemClipboard": true,
  "python.analysis.typeCheckingMode": "standard",
  "chat.tools.terminal.autoApprove": {
    "go": true,
    "sed": true,
    "./lpcli": true,
    "air": true,
    "layout).tsx$\"": true,
    "npm install": true,
    "TestAppCreateHandler_MultipleServicesWithPortMappings\"": true,
    "FAIL": true,
    "ok": true,
    "^---)\"": true,
    "sqlite3": true,
    "make": true,
    "find": true,
    "}": true,
    "docker buildx": true,
    "npm run lint": true,
    "kubectl logs": true,
    "kind load docker-image localisprod-ui:local --name localisprod-dev": {
      "approve": true,
      "matchCommandLine": true,
    },
    "kubectl rollout restart deployment/ui -n localisprod": {
      "approve": true,
      "matchCommandLine": true,
    },
    "kubectl rollout status deployment/ui -n localisprod": {
      "approve": true,
      "matchCommandLine": true,
    },
    "cd /Users/gsarma/work/localisprod && docker build -t localisprod-lpserver:local .": {
      "approve": true,
      "matchCommandLine": true,
    },
    "kind load docker-image localisprod-lpserver:local --name localisprod-dev && kubectl rollout restart deployment/lpserver -n localisprod": {
      "approve": true,
      "matchCommandLine": true,
    },
    "kind load docker-image localisprod-lpserver:local --name localisprod-dev": {
      "approve": true,
      "matchCommandLine": true,
    },
    "kubectl rollout restart deployment/lpserver -n localisprod": {
      "approve": true,
      "matchCommandLine": true,
    },
    "kubectl rollout status deployment/lpserver -n localisprod": {
      "approve": true,
      "matchCommandLine": true,
    },
    "./setup-kind.sh": true,
    "kubectl delete": true,
    "kubectl apply": true,
    "kubectl get": true,
    "cargo build": true,
    "cargo run": true,
    "CREATE": true,
    "INSERT": true,
    "DELETE": true,
    "EXPLAIN": true,
    "\"": true,
  },
}
